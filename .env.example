# ── Google Cloud ─────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=asia-northeast1
# Use Application Default Credentials locally: `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json   # only if not using ADC

# ── Models (Gemini) ──────────────────────────────────────────
# Provider-agnostic Model Service config. Pin versions for deterministic demos.
AEGIS_MODEL_DEEP=gemini-2.5-pro
AEGIS_MODEL_FAST=gemini-2.5-flash
AEGIS_MODEL_CHEAP=gemma-3
# Set true to use the Vertex AI backend, false for the Google AI (api key) backend
GOOGLE_GENAI_USE_VERTEXAI=true
# GEMINI_API_KEY=...   # only when GOOGLE_GENAI_USE_VERTEXAI=false

# ── Aegis runtime ────────────────────────────────────────────
AEGIS_ENV=local                 # local | cloud
AEGIS_DEMO_MODE=true            # deterministic, seeded scenarios for the demo
AEGIS_LOOP_MAX_STEPS=12         # hard cap to prevent unbounded looping
AEGIS_AUTONOMY=guarded          # guarded (L2 needs approval) | shadow (no actions)

# ── Stores (optional in local mode) ──────────────────────────
BIGQUERY_DATASET=aegis
FIRESTORE_DATABASE=(default)
ELASTICSEARCH_URL=               # optional; falls back to in-memory KB if empty
ELASTICSEARCH_API_KEY=

# ── Integrations (optional) ──────────────────────────────────
GITHUB_REPO=                     # owner/repo for deploy events + hotfix PRs
SLACK_WEBHOOK_URL=               # optional postmortem channel
